APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

META_PAGE_ID=
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
COHERE_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
ZEN_API_KEY=
ZEN_BASE_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────
# AI Sales Agent — LLM Provider Config
# ─────────────────────────────────────
AGENT_PROVIDER=smart
AGENT_ROUTER_STRATEGY=smart
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=2048

# Agent-specific overrides
AGENT_COMMENT_PROVIDER=smart
AGENT_QUALIFIER_PROVIDER=smart
AGENT_SUPPORT_PROVIDER=smart

# ─── OpenAI ───
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── Anthropic (Claude) ───
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3.5-sonnet

# ─── Google Gemini ───
# Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-pro

# ─── Groq (fast + free) ───
# Get key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# ─── Ollama (local, free) ───
# Install: https://ollama.com
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── OpenRouter (aggregator, 200+ models) ───
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── Mistral AI ───
MISTRAL_API_KEY=

# ─── DeepSeek ───
DEEPSEEK_API_KEY=

# ─── Together AI ───
TOGETHER_API_KEY=

# ─── Cohere ───
COHERE_API_KEY=

# ─── OpenCode Zen (Big Pickle — مجاني) ───
# Big Pickle موديل مجاني 200K context
# API: https://opencode.ai/zen/v1/chat/completions
ZEN_API_KEY=
ZEN_MODEL=big-pickle
